DATABASE_URL=postgresql+asyncpg://invoice_user:invoice_pass@localhost:5432/invoice_db
REDIS_URL=redis://localhost:6379

SECRET_KEY=dev-secret-key-replace-in-production
COOKIE_SECURE=false

STORAGE_BACKEND=local
ARTIFACT_STORAGE_ROOT=./artifacts
# Production (Azure Blob):
# STORAGE_BACKEND=azure_blob
# STORAGE_BUCKET=<container-name>
# STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net

# mock | vision_llm — mock is the default for local dev, no API key needed
EXTRACTION_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_EXTRACTION_MODEL=claude-opus-4-8

# Microsoft Graph email intake
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
INTAKE_MAILBOX=
GRAPH_WEBHOOK_CLIENT_STATE=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development
DEBUG=true
